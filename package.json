{
  "name": "@eq-solutions/ui",
  "version": "1.0.0",
  "private": false,
  "license": "UNLICENSED",
  "author": "CDC Solutions Pty Ltd",
  "description": "Canonical EQ shared React components (Button, Skeleton, Table, …) consuming @eq-solutions/tokens. Companion to @eq-solutions/tokens + @eq-solutions/roles.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eq-solutions/eq-ui.git"
  },
  "homepage": "https://github.com/eq-solutions/eq-ui",
  "bugs": {
    "url": "https://github.com/eq-solutions/eq-ui/issues"
  },
  "keywords": [
    "eq-solutions",
    "design-system",
    "react",
    "components",
    "ui"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./Button": {
      "types": "./src/Button/Button.tsx",
      "default": "./src/Button/Button.tsx"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src/",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eq-solutions/tokens": "github:eq-solutions/eq-design-tokens#v1.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
